# Ambiente
NODE_ENV="production"
HOST="0.0.0.0"
PORT="3333"

# Banco SQLite/libSQL.
# Para volume local persistente, use um caminho dentro do volume montado.
DATABASE_URL="file:/data/fluxo.db"

# Troque por um segredo longo e aleatorio antes de publicar.
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio"

# Quando o server serve o frontend no mesmo dominio, CORS deixa de ser usado pelo browser.
# Mantenha preenchido caso ainda exista algum frontend separado.
CORS_ORIGIN="https://seu-dominio.com"

# Em production o padrao ja e true, mas fica explicito para deploy.
SERVE_WEB="true"
WEB_DIST_PATH="../web/dist"
