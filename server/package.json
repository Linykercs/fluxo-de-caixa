{
  "name": "@fluxo/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:migrate": "tsx scripts/apply-migrations.ts",
    "db:seed": "prisma db seed",
    "db:reset": "tsx scripts/reset-db.ts && prisma db seed",
    "db:studio": "prisma studio",
    "org:create": "tsx scripts/create-organization.ts",
    "seed:triari": "tsx scripts/seed-triari.ts",
    "reset-password": "tsx scripts/reset-password.ts",
    "telegram:set-webhook": "tsx scripts/set-telegram-webhook.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@fluxo/shared": "*",
    "@libsql/client": "^0.17.3",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "baileys": "^7.0.0-rc13",
    "fastify": "^5.6.2",
    "qrcode": "^1.5.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "prisma": "^7.8.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
