# Caminho do banco SQLite (relativo à pasta server/)
DATABASE_URL="file:./prisma/dev.db"

# Segredo para assinatura do JWT de sessão (cookie httpOnly)
JWT_SECRET="dev-secret-troque-em-producao"

# Origem permitida no CORS (dev do Vite)
CORS_ORIGIN="http://localhost:5173"

# Servir o build do frontend pelo Fastify. Em production o padrao ja e true.
SERVE_WEB="false"
WEB_DIST_PATH="../web/dist"

# Bot do Telegram para lembretes de vencimento (opcional; sem isso a feature fica desativada).
# Token vem do @BotFather. O username (sem @) e usado so para montar o link de convite.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
# Segredo qualquer (ex: gerado com `openssl rand -hex 20`) que compoe a URL do webhook,
# pra ninguem alem do Telegram conseguir chamar essa rota.
TELEGRAM_WEBHOOK_SECRET=""

# WhatsApp nao oficial (whatsapp-web.js): sessao unica do servidor, escaneada 1x por QR code.
# Pesado (roda um Chromium); por isso e opt-in mesmo com Telegram ja configurado.
WHATSAPP_ENABLED="false"
# Onde fica salva a sessao logada (sobrevive a restart). Em producao, use um caminho
# dentro do volume persistente, ex: "/data/whatsapp-session".
WHATSAPP_SESSION_PATH="./.whatsapp-session"
# So precisa setar se quiser usar um Chromium especifico do sistema; por padrao
# (vazio) o puppeteer baixa e usa o proprio Chromium dele, mais confiavel.
PUPPETEER_EXECUTABLE_PATH=""
